# Indexes Scraper - Configurações via environment
# Copie para .env e ajuste conforme necessário

# Diretório de saída dos JSONs (padrão: output/)
# INDEXES_OUTPUT_DIR=output

# Formato de log: text ou json (padrão: text)
# INDEXES_LOG_FORMAT=text

# Nível de log: DEBUG, INFO, WARNING, ERROR (padrão: INFO)
# INDEXES_LOG_LEVEL=INFO

# Modo headless do Chrome: true ou false (padrão: true)
# INDEXES_HEADLESS=true

# User agent do Chrome (padrão: Chrome 120)
# INDEXES_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# Porta da API (padrão: 8000)
# INDEXES_API_PORT=8000